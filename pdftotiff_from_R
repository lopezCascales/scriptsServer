pdf_path <- "BC-seq and metastasis signature_Supplementary-2-10.pdf"
# Leer todos los TIFFs generados y combinarlos en uno
n_pages <- pdf_info(pdf_path)$pages
tiff_files <- paste0("figura_", 1:n_pages, ".tiff")


library(magick)

pages <- image_read(tiff_files)

image_write(pages,
            path    = "supplementary_combined.tiff",
            format  = "tiff",
            quality = 100)
